# PostgreSQL connection (required)
DATABASE_URL=postgresql://game:game@127.0.0.1:5435/shakti_game

# HTTP port for the API
APP_PORT=8010

# tracing-subscriber filter: error, warn, info, debug
RUST_LOG=info

# LLM backend for session preparation when options.llmPreparationEnabled is true:
#   mock   — no external call (default); enriches metadata only
#   openai — Chat Completions via OPENAI_API_KEY
GAME_ENGINE_LLM_MODE=mock

# OpenAI (required when GAME_ENGINE_LLM_MODE=openai)
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
